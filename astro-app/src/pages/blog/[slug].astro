---
/**
 * Dynamic blog post route — Sprint 3.
 * Renders one static page per markdown file in src/content/blog/.
 * Auto-derives the cross-link "les også" target as the chronologically
 * adjacent post (matches main's post-nav behavior — wraps to first when
 * we run out).
 *
 * Flat-slug URL note: still under /blog/<slug>/. Migration to flat slugs
 * remains a Sprint 4 task per CEO directive (feedback_naming.md).
 */
import { getCollection, render } from 'astro:content';
import Post from '../../layouts/Post.astro';

export async function getStaticPaths() {
  const all = (await getCollection('blog', ({ data }) => !data.draft)).sort(
    (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
  );

  const formatter = new Intl.DateTimeFormat('nb-NO', {
    year: 'numeric',
    month: 'long',
  });

  return all.map((post, i) => {
    const next = all[(i + 1) % all.length];
    return {
      params: { slug: post.id },
      props: {
        post,
        nextPost: {
          href: `/blog/${next.id}/`,
          title: next.data.title,
          date: formatter.format(next.data.date),
          label: 'les også',
        },
      },
    };
  });
}

const { post, nextPost } = Astro.props;
const { Content } = await render(post);
---

<Post
  title={post.data.title}
  slug={post.data.slug}
  date={post.data.date}
  excerpt={post.data.excerpt}
  hero_image={post.data.hero_image}
  hero_alt={post.data.hero_alt}
  hero_caption={post.data.hero_caption}
  kicker={post.data.kicker}
  ogImage={post.data.og_image}
  footerSub={post.data.footer_sub}
  tags={post.data.tags}
  nextPost={nextPost}
>
  <Content />
</Post>
